# Gemini API Key — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server config
PORT=3000
NODE_ENV=development

# Shopify Storefront API — for live product data (prices, availability)
# Token: Shopify Admin → Settings → Apps → asterley-bros-local-dev → API credentials
SHOPIFY_STOREFRONT_TOKEN=your_storefront_token_here
SHOPIFY_STORE_DOMAIN=asterley-bros.myshopify.com

# Admin API key — required to access /api/admin/* routes
# Generate any random string, e.g: openssl rand -hex 32
ADMIN_API_KEY=your_admin_key_here

# Email platform for newsletter sign-up: "klaviyo" | "mailchimp" | "firestore" (default)
EMAIL_PLATFORM=firestore

# Klaviyo — only needed if EMAIL_PLATFORM=klaviyo
# Public API key (starts with pk_): Klaviyo → Settings → API Keys
KLAVIYO_API_KEY=your_klaviyo_public_key_here
# List ID: Klaviyo → Lists & Segments → (select list) → Settings
KLAVIYO_LIST_ID=your_list_id_here

# Mailchimp — only needed if EMAIL_PLATFORM=mailchimp
# API key: Mailchimp → Account → Extras → API Keys
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
# List/Audience ID: Mailchimp → Audience → Settings → Audience name and defaults
MAILCHIMP_LIST_ID=your_audience_id_here
# Server prefix from your API key, e.g. "us21"
MAILCHIMP_SERVER=us1
